{
  "name": "bookbiteflow",
  "version": "1.0.0",
  "private": true,
  "description": "BookBiteFlow Admin Dashboard — Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@bookbiteflow/web",
    "dev:api": "turbo run dev --filter=@bookbiteflow/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @bookbiteflow/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @bookbiteflow/api exec tsx prisma/seed.ts",
    "db:studio": "pnpm --filter @bookbiteflow/api exec prisma studio",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  }
}
