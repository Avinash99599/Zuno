# ─── Database (Supabase PostgreSQL) ───
DATABASE_URL="postgresql://postgres:password@localhost:5432/bookbiteflow?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/bookbiteflow?schema=public"

# ─── JWT ───
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── External APIs (MOCK — replace when real API contract is confirmed) ───
CUSTOMER_API_BASE_URL=http://localhost:3001/api/mock
RESTAURANT_API_BASE_URL=http://localhost:3001/api/mock

# ─── Cloudinary ───
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Google Maps ───
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
